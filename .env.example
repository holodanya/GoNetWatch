# ─── InfluxDB ────────────────────────────────────────────────────────────────
# Admin credentials for the InfluxDB web UI and CLI (used on first start only)
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=changeme_strong_password

# Org and bucket (must match configs/config.yaml influxdb.org / influxdb.bucket)
INFLUXDB_ORG=gonetwatch
INFLUXDB_BUCKET=network_metrics

# Access token — used by GoNetWatch to write metrics and by Grafana to query them.
# Must be the same value for both. Generate with:  openssl rand -hex 32
INFLUX_TOKEN=changeme_replace_with_a_long_random_string

# ─── Grafana ─────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme_strong_password

# ─── Telegram alerts (optional) ───────────────────────────────────────────────
# Leave empty to disable. Bot token from @BotFather; chat IDs comma-separated.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=
