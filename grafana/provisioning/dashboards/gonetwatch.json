                    "query": {
                      "datasource": {
                        "name": "influxdb"
                      },
                      "group": "influxdb",
                      "kind": "DataQuery",
                      "spec": {
                        "query": "from(bucket: \"network_metrics\")\r\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\r\n  |> filter(fn: (r) => r[\"_measurement\"] == \"network_latency\")\r\n  |> filter(fn: (r) => r[\"_field\"] == \"success\")\r\n  |> filter(fn: (r) => r[\"target\"] =~ /^${target:regex}$/)\r\n  |> group(columns: [\"target\"])\r\n  |> reduce(\r\n      identity: {\r\n        total_checks: 0,\r\n        failed_checks: 0\r\n      },\r\n      fn: (r, accumulator) => ({\r\n        total_checks: accumulator.total_checks + 1,\r\n        failed_checks: accumulator.failed_checks + (if r._value == false then 1 else 0)\r\n      })\r\n    )\r\n  |> map(fn: (r) => ({\r\n      row: \"Failure Rate\",\r\n      target: r.target,\r\n      _value: if r.total_checks == 0 then 0.0 else (float(v: r.failed_checks) / float(v: r.total_checks)) * 100.0\r\n    }))\r\n  |> keep(columns: [\"row\", \"target\", \"_value\"])\r\n  |> group()\r\n  |> pivot(rowKey: [\"row\"], columnKey: [\"target\"], valueColumn: \"_value\")\r\n  |> drop(columns: [\"row\"])"
                      },
