      "panel-6": {
        "kind": "Panel",
        "spec": {
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "hidden": false,
                    "query": {
                      "datasource": {
                        "name": "influxdb"
                      },
                      "group": "influxdb",
                      "kind": "DataQuery",
                      "spec": {
                        "query": "import \"array\"\r\n\r\nfailed =\r\n  from(bucket: \"network_metrics\")\r\n    |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\r\n    |> filter(fn: (r) => r[\"_measurement\"] == \"network_latency\")\r\n    |> filter(fn: (r) => r[\"_field\"] == \"success\")\r\n    |> filter(fn: (r) => r[\"target\"] =~ /^${target:regex}$/)\r\n    |> filter(fn: (r) => r[\"_value\"] == false)\r\n    |> group(columns: [])\r\n    |> count(column: \"_value\")\r\n    |> keep(columns: [\"_value\"])\r\n    |> map(fn: (r) => ({ r with metric: \"Total Failed Checks\" }))\r\n\r\nzero =\r\n  array.from(rows: [\r\n    {metric: \"Total Failed Checks\", _value: 0}\r\n  ])\r\n\r\nunion(tables: [failed, zero])\r\n  |> group(columns: [\"metric\"])\r\n  |> sum(column: \"_value\")\r\n  |> map(fn: (r) => ({ r with row: \"result\" }))\r\n  |> pivot(rowKey: [\"row\"], columnKey: [\"metric\"], valueColumn: \"_value\")\r\n  |> drop(columns: [\"row\"])"
                      },
