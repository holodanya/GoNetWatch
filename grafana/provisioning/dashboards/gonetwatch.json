                      "group": "influxdb",
                      "kind": "DataQuery",
                      "spec": {
                        "query": "import \"array\"\r\n\r\ndata =\r\n  from(bucket: \"network_metrics\")\r\n    |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\r\n    |> filter(fn: (r) => r[\"_measurement\"] == \"network_latency\")\r\n    |> filter(fn: (r) => r[\"_field\"] == \"success\")\r\n    |> filter(fn: (r) => r[\"target\"] =~ /^${target:regex}$/)\r\n    |> map(fn: (r) => ({ r with state: if r._value == true then \"UP\" else \"DOWN\" }))\r\n    |> group(columns: [\"state\"])\r\n    |> count(column: \"_value\")\r\n    |> keep(columns: [\"state\", \"_value\"])\r\n\r\nzeros =\r\n  array.from(rows: [\r\n    {state: \"UP\", _value: 0},\r\n    {state: \"DOWN\", _value: 0}\r\n  ])\r\n\r\nunion(tables: [data, zeros])\r\n  |> group(columns: [\"state\"])\r\n  |> sum(column: \"_value\")\r\n  |> map(fn: (r) => ({ r with row: \"availability\" }))\r\n  |> pivot(rowKey: [\"row\"], columnKey: [\"state\"], valueColumn: \"_value\")\r\n  |> drop(columns: [\"row\"])"
                      },
                      "version": "v0"
                    },
                    "refId": "A"
